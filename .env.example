# Site URL (used for metadata, share links, Open Graph base)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Telegram bot username without @
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername

# Fallback start param when no placement is passed (legacy; placements override per CTA)
NEXT_PUBLIC_DEFAULT_TELEGRAM_START=web_main

NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
# Optional WhatsApp deep link, e.g. https://wa.me/34123456789
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Set to "false" to hide verify CTA on the landing page
NEXT_PUBLIC_ENABLE_VERIFY=true

# Set to "false" to hide share button in final CTA block
NEXT_PUBLIC_ENABLE_SHARE=true

# Optional: public URL for GuduX FX product (otherwise /gudux-fx placeholder)
# NEXT_PUBLIC_GUDUX_FX_URL=https://gudux.example.com
